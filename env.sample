# Copy what you need. Web app reads NEXT_PUBLIC_* at build time; the CLI reads the rest
# from the environment or from ~/.backlog/env. Never commit real secrets.

# --- Web app (Next.js on Railway) ---
NEXT_PUBLIC_BACKLOG_ADDRESS=0x0000000000000000000000000000000000000000

# --- CLI (`node cli/sync.mjs`), best kept in ~/.backlog/env ---
# BACKLOG_ADDRESS=0x...              # same deployed contract address
# BACKLOG_PRIVATE_KEY=0x...          # wallet that owns your portfolio (signs the batch write)
# ANTHROPIC_API_KEY=sk-ant-...       # scores each project; omit for heuristic scoring
# BACKLOG_PROJECTS_DIR=/home/you/projects   # defaults to ~/projects
# BACKLOG_RPC=https://rpc.monad.xyz
# BACKLOG_MODEL=claude-sonnet-5
